{
  "name": "lexos",
  "version": "0.1.0",
  "description": "Vocabulary middleware platform for voice ordering systems",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify-migration": "ts-node scripts/verify-migration.ts",
    "backfill-embeddings": "ts-node -r dotenv/config scripts/backfill-embeddings.ts",
    "train-classifier": "ts-node -r dotenv/config scripts/train-intent-classifier.ts",
    "ingest-menu": "ts-node -r dotenv/config scripts/ingest-menu.ts",
    "eval": "ts-node -r dotenv/config scripts/run-intent-eval.ts",
    "eval-traps": "ts-node -r dotenv/config scripts/eval-traps.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@supabase/supabase-js": "^2.43.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "langsmith": "^0.1.55",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "pg": "^8.21.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
