# ──────────────────────────────────────────────────────────
# LEXOS — Environment Variables
# Copy this file to .env and fill in the real values.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────

# ── Supabase ───────────────────────────────────────────────
# Supabase dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Anthropic (Claude) ─────────────────────────────────────
# Required for the demo UI "without Lexos" comparison panel.
# console.anthropic.com → Settings → Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare Workers AI (embeddings) ────────────────────
# Required for semantic search and menu grounding.
# Cloudflare dashboard → Workers & Pages → your account
CLOUDFLARE_ACCOUNT_ID=<account-id>
CLOUDFLARE_API_TOKEN=<api-token>

# ── LangSmith tracing (optional) ──────────────────────────
# Leave blank to disable. smith.langchain.com → Settings → API Keys
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=lexos
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── API keys ───────────────────────────────────────────────
# Master key for /enrich and /retrieve (production only).
# Leave blank in local dev — auth is skipped when unset.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LEXOS_API_KEY=<generated-secret>

# Admin dashboard key — protects all /admin routes (X-Admin-Key header).
LEXOS_ADMIN_KEY=<generated-secret>

# ── Classifier / matching thresholds ──────────────────────
# All have sensible defaults — only override if tuning.
INTENT_MATCH_THRESHOLD=0.55
PHONETIC_AMBIGUITY_THRESHOLD=0.85
CLASSIFIER_PROB_THRESHOLD=0.15
CLASSIFIER_OOD_SIM_FLOOR=0.40
MENU_ITEM_SIM_FLOOR=0.62

# ── Vocabulary generation (off by default) ────────────────
# Keep false. All vocab generation is done by Claude Code in conversation.
GENERATION_ENABLED=false
